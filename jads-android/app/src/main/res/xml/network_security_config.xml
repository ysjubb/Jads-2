<?xml version="1.0" encoding="utf-8"?>
<!--
    JADS Network Security Configuration
    ─────────────────────────────────────────────────────────────────────────────
    Production: backend must serve HTTPS. This config is for demo / development
    where the backend runs on a LAN laptop without a TLS certificate.

    Cleartext (HTTP) is permitted ONLY for:
      • localhost / 127.0.0.1     — emulator testing
      • 10.x.x.x                  — common mobile hotspot / enterprise LAN
      • 192.168.x.x               — common home / venue WiFi
      • 172.16–31.x.x             — RFC 1918 range

    All other traffic (public internet) remains HTTPS-only.

    To switch to production (HTTPS everywhere):
      Replace this file with:
        <network-security-config>
            <base-config cleartextTrafficPermitted="false" />
        </network-security-config>
-->
<network-security-config>

    <!-- Deny cleartext on all public internet traffic -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow cleartext for LAN addresses used during demo -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.0</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>       <!-- Android emulator host -->
        <domain includeSubdomains="false">192.168.0.1</domain>
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.43.1</domain>    <!-- Android hotspot default gateway -->
    </domain-config>

</network-security-config>
