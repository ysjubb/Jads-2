# JADS Backend — npm configuration for supply-chain hardening.
# CERT-In VAPT compliance: pin registry, enforce integrity, prevent confusion attacks.

# Pin to official npm public registry
registry=https://registry.npmjs.org/

# Enforce package-lock.json integrity hashes (SHA-512)
# Fail install if any package doesn't match lockfile
package-lock=true

# Prevent scripts from running during install (supply-chain attack vector)
# Run "npm rebuild" explicitly after install if native addons need compilation.
ignore-scripts=true

# Strict SSL — never disable certificate verification
strict-ssl=true

# Save exact versions (no ^ or ~ prefix) for reproducible builds
save-exact=true

# Audit production dependencies on every install
audit=true
