{
  "name": "jads-backend",
  "version": "4.0.0",
  "description": "JADS Platform v4.0 — Backend API Server",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc --noEmit && tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "sbom": "npx @cyclonedx/cyclonedx-npm --output-file sbom.json --output-format JSON",
    "audit:ci": "npm audit --audit-level=high --omit=dev"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.2.0",
    "@prisma/client": "^5.10.0",
    "asn1js": "3.0.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "crc-32": "^1.2.2",
    "express": "^4.18.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/asn1js": "3.0.6",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.20",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^7.1.1",
    "@typescript-eslint/parser": "^7.1.1",
    "dotenv": "^16.4.5",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "prisma": "^5.10.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  }
}
