# JADS Platform v4.0 — Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# Required variables will cause an immediate process.exit(1) if missing.

# ── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://jads:password@localhost:5432/jads_dev

# ── Auth Secrets (generate with: openssl rand -hex 64) ──────────────────
# User app JWTs — 8 hour sessions
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET

# Admin portal JWTs — 2 hour sessions (MUST be different from JWT_SECRET)
ADMIN_JWT_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET

# Inbound adapter webhook key — used by AFMLU and FIR office systems
# Include in X-JADS-Adapter-Key header on all push webhook requests
# (generate with: openssl rand -hex 32)
ADAPTER_INBOUND_KEY=REPLACE_WITH_32_BYTE_HEX_SECRET

# ── Government System Integrations ────────────────────────────────────────
# Set USE_LIVE_ADAPTERS=true only when live endpoints are configured
USE_LIVE_ADAPTERS=false

DIGITAL_SKY_BASE_URL=https://digitalsky.dgca.gov.in
DIGITAL_SKY_API_KEY=

UIDAI_BASE_URL=https://api.uidai.gov.in
UIDAI_API_KEY=

AFMLU_BASE_URL=
AFMLU_API_KEY=

FIR_BASE_URL=
AFTN_GATEWAY_HOST=
AFTN_GATEWAY_PORT=0

METAR_BASE_URL=
NOTAM_BASE_URL=

# ── Demo / ngrok mode (T03) ────────────────────────────────────────────
# Set DEMO_MODE=true when showcasing the platform via ngrok tunnel.
# JADS_PUBLIC_URL / JADS_WS_URL are the ngrok-provided public addresses.
DEMO_MODE=false
JADS_PUBLIC_URL=
JADS_WS_URL=
DEMO_CORS_ORIGINS=
DEMO_MISSION_ID=demo-mission-001
DEMO_REPLAY_SPEED=1

# ── RFC 3161 Trusted Timestamping (optional) ──────────────────────────
# Provides forensic-grade temporal proof via CCA-licensed TSA.
# Indian TSAs: CDAC (http://tsa.cdac.in), eMudhra (https://tsa.emudhra.com)
RFC3161_TSA_URL=
RFC3161_TSA_USERNAME=
RFC3161_TSA_PASSWORD=
RFC3161_TSA_TIMEOUT_MS=15000
RFC3161_TOKEN_STORE_PATH=
