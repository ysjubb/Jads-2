// JADS Platform v4.0 — Prisma Schema
// AUTHORITATIVE SOURCE: matches migration SQL exactly.
// Never modify field names here without a corresponding migration.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// ENUMS — must match migration SQL CREATE TYPE
// ═══════════════════════════════════════════════

enum UserRole {
  PILOT
  DRONE_OPERATOR
  PILOT_AND_DRONE
  GOVT_PILOT
  GOVT_DRONE_OPERATOR
  GOVT_ADMIN
  PLATFORM_SUPER_ADMIN
  DGCA_AUDITOR
  AAI_AUDITOR
  IAF_AUDITOR
  ARMY_AUDITOR
  NAVY_AUDITOR
  INVESTIGATION_OFFICER
}

enum IdentityVerificationStatus {
  PENDING
  VERIFIED
  REVERIFICATION_DUE
  EXPIRED
  SUSPENDED
  REVOKED
}

enum UserAccountStatus {
  PENDING_APPROVAL
  ACTIVE
  SUSPENDED
  REVOKED
}

enum AirspaceDataSource {
  DGCA_MANUAL
  AAI_AIP
  NOTAM_DERIVED
  IAF_CLASSIFIED
  ADMIN_OVERRIDE
  MANUAL
}

enum AirspaceApprovalStatus {
  DRAFT
  PENDING
  ACTIVE
  EXPIRED
  REJECTED
  WITHDRAWN
  SUPERSEDED
}

enum NpntClass {
  GREEN   // Unrestricted — fly without permission artefact
  YELLOW  // Controlled — requires NPNT PA from Digital Sky
  RED     // Prohibited — no civil drone operations
}

// DGCA UAS Rules 2021 weight categories
enum DroneWeightCategory {
  NANO        // < 250g — exempt from NPNT, no UIN required
  MICRO       // 250g – 2kg — simplified registration, NPNT in controlled airspace only
  SMALL       // 2kg – 25kg — full NPNT, UIN required
  MEDIUM      // 25kg – 150kg — full NPNT, UIN + type certificate required
  LARGE       // > 150kg — treated as manned aircraft category
  UNKNOWN     // category not specified (legacy submissions)
}

// Source of manufacturer-pushed telemetry
enum ManufacturerPushSource {
  DJI
  AUTEL
  PARROT
  SKYDIO
  IDEAFORGE   // ideaForge Technology Ltd — ~50% of Indian govt drone market
  ASTERIA     // Asteria Aerospace
  THROTTLE    // Throttle Aerospace
  GENERIC     // Unknown or unlisted OEM
}

// Status of a deferred sync batch
enum DeferredSyncStatus {
  QUEUED      // received, pending processing
  PROCESSING  // being validated and ingested
  COMPLETE    // all records ingested successfully
  PARTIAL     // some records failed validation
  REJECTED    // authentication or format failure
}

enum NtpSyncStatus {
  SYNCED
  DEGRADED
  FAILED
}

enum MissionUploadStatus {
  PENDING
  PROCESSING
  COMPLETE
  FAILED
}

enum ViolationType {
  GEOFENCE_BREACH
  ALTITUDE_VIOLATION
  SPEED_VIOLATION
  TIME_WINDOW_VIOLATION
  CHAIN_BREAK
  REPLAY_ATTEMPT
  GPS_SPOOFING_SUSPECTED
  UNPERMITTED_ZONE
}

enum ViolationSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FlightRules {
  IFR
  VFR
  SVFR
  Y
  Z
}

enum FlightType {
  S
  N
  G
  M
  X
}

// PA (Permission Artefact) lifecycle states per NPNT compliance
enum PAStatus {
  PENDING
  APPROVED
  DOWNLOADED
  LOADED
  ACTIVE
  COMPLETED
  LOG_UPLOADED
  AUDIT_COMPLETE
  EXPIRED
  REJECTED
  REVOKED
}

enum FlightPlanStatus {
  DRAFT
  VALIDATED
  FILED
  FILING_FAILED
  ACKNOWLEDGED
  ACTIVATED
  COMPLETED
  CANCELLED
  DELAYED
  OVERDUE
  REJECTED_BY_ATC
  CLEARANCE_REJECTED
  PENDING_CLEARANCE
  ADC_ISSUED
  FIC_ISSUED
  FULLY_CLEARED
  ARRIVED
  STUB_TRANSMITTED  // FPL built + logged — NOT transmitted to AAI AMHS (stub mode)
  VOID              // Auto-cancelled — no DEP received within ICAO Doc 4444 §4.10 validity window
  DEPARTED          // Aircraft departed — DEP message (Phase 2; not yet implemented)
}

enum CredentialDomain {
  AIRCRAFT
  DRONE
}

enum IssuingAuthority {
  AAI
  DGCA
  DIGITAL_SKY
}

// ═══════════════════════════════════════════════
// MODELS
// ═══════════════════════════════════════════════

model CivilianUser {
  id                    String                     @id @default(cuid())
  aadhaarHash           String?                    @unique
  phone                 String?
  mobileNumber          String?                    @unique
  email                 String?
  role                  UserRole                   @default(PILOT)
  credentialDomain      CredentialDomain
  issuingAuthority      IssuingAuthority
  credentialSyncedAt    DateTime?
  credentialExternalId  String?
  dgcaLicenseNumber     String?
  dgcaLicenseExpiry     DateTime?
  pilotLicenceNumber    String?
  uinNumber             String?
  identityStatus        IdentityVerificationStatus @default(PENDING)
  verificationStatus    IdentityVerificationStatus @default(PENDING)
  accountStatus         UserAccountStatus          @default(PENDING_APPROVAL)
  // Aadhaar fields
  aadhaarLast4          String?
  aadhaarUidToken       String?
  aadhaarNextDueAt      DateTime?
  aadhaarVerifiedAt     DateTime?
  maskedAadhaarNumber   String?
  // Verification timestamps
  emailVerifiedAt       DateTime?
  mobileVerifiedAt      DateTime?
  lastVerificationAt    DateTime?
  nextReverificationDue DateTime?
  // Standard timestamps
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt
  lastLoginAt           DateTime?
  annualReconfirmDue    DateTime?

  flightPlans           MannedFlightPlan[]         @relation("FiledByCivilian")
}

model SpecialUser {
  id                    String            @id @default(cuid())
  username              String            @unique
  passwordHash          String
  unitDesignator        String
  entityCode            String
  role                  UserRole          @default(GOVT_DRONE_OPERATOR)
  credentialDomain      CredentialDomain
  issuingAuthority      IssuingAuthority
  credentialSyncedAt    DateTime?
  credentialExternalId  String?
  accountStatus         UserAccountStatus @default(ACTIVE)
  provisionedBy         String
  provisionedAt         DateTime          @default(now())
  lastLoginAt           DateTime?
  passwordLastChanged   DateTime          @default(now())
  unitName              String?
  forcePasswordChange   Boolean           @default(false)
  unitType              String?
  baseLocation          String?
  createdBy             String?
  createdAt             DateTime          @default(now())
  credentialsIssuedAt   DateTime?
  lastPasswordChangedAt DateTime?
  suspendedAt           DateTime?
  suspendedReason       String?
  // Additional unit fields
  serviceNumber         String?
  officialEmail         String?
  mobileNumber          String?
  unitDesignation       String?
  authorisedCallsigns   String[]          @default([])
  // Reconfirmation fields
  reconfirmationStatus  String?
  lastReconfirmedAt     DateTime?
  nextReconfirmDueAt    DateTime?
  nextAdminReconfirmDue DateTime?
  lastAdminReconfirmAt  DateTime?
  annualReconfirmDue    DateTime?
  createdByAdminId      String?

  entityRights          GovtAdminEntityRights[]
  flightPlans           MannedFlightPlan[]       @relation("FiledBySpecial")
}

model GovtAdminEntityRights {
  id                 String      @id @default(cuid())
  specialUserId      String
  adminUserId        String?
  entityCode         String
  canViewMissions    Boolean     @default(true)
  canViewFlightPlans Boolean     @default(true)
  canViewViolations  Boolean     @default(true)
  canExportForensic  Boolean     @default(false)
  isActive           Boolean     @default(true)
  grantedBy          String
  grantedByAdminId   String?
  grantedAt          DateTime    @default(now())

  specialUser        SpecialUser @relation(fields: [specialUserId], references: [id])
}

model InvestigationAccess {
  id              String    @id @default(cuid())
  grantedToUserId String
  missionId       String?
  flightPlanId    String?
  reason          String
  grantedBy       String
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime
}

model AuditLog {
  id             String    @id @default(cuid())
  timestamp      DateTime  @default(now())
  actorId        String
  actorType      String
  actorRole      String?
  action         String
  resourceType   String
  resourceId     String?
  ipAddress      String?
  userAgent      String?
  success        Boolean?
  errorCode      String?
  detailJson     String
  sequenceNumber BigInt    @default(autoincrement())
  // Defense 6: Row-level hash for tamper detection.
  // Computed on INSERT as SHA-256(id || sequenceNumber || timestamp || actorId || action || detailJson).
  // If an attacker with DB access modifies any field, the hash won't match on re-verification.
  rowHash        String?

  @@index([actorId])
  @@index([resourceType, resourceId])
  @@index([timestamp])
  @@index([sequenceNumber])
}

model AdminUser {
  id            String            @id @default(cuid())
  username      String            @unique
  passwordHash  String
  role          UserRole          @default(GOVT_ADMIN)
  entityCode    String
  accountStatus UserAccountStatus @default(ACTIVE)
  createdAt     DateTime          @default(now())
  lastLoginAt   DateTime?
}

model OtpRecord {
  id         String    @id @default(cuid())
  phone      String?
  targetId   String?
  targetType String?
  otpHash    String
  purpose    String
  expiresAt  DateTime
  usedAt     DateTime?
  attempts   Int       @default(0)
  createdAt  DateTime  @default(now())
}

model AirspaceVersion {
  id              String                 @id @default(cuid())
  dataType        String
  versionNumber   Int
  payloadJson     String
  payloadHash     String?
  approvalStatus  AirspaceApprovalStatus @default(DRAFT)
  dataSource      AirspaceDataSource     @default(ADMIN_OVERRIDE)
  airacCycle      String?
  effectiveFrom   DateTime
  effectiveTo     DateTime?
  changeReason    String
  createdBy       String
  approvedBy      String?
  rejectedBy      String?
  createdAt       DateTime               @default(now())
  approvedAt      DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  supersedes      String?
  supersededById  String?

  @@index([dataType])
  @@index([approvalStatus])
}

model MannedFlightPlan {
  id                       String           @id @default(cuid())
  flightPlanId             BigInt?
  filedBy                  String
  filedByType              String           @default("CIVILIAN")
  aftnMessage              String?
  aftnAddressees           String?
  aftnTransmissionId       String?
  ficNumber                String?
  adcNumber                String?
  atsRef                   String?
  notifyEmail              String?
  notifyMobile             String?
  filedAt                  DateTime?
  clearedAt                DateTime?
  item18                   String?
  item19                   String?
  item10Equipment          String[]         @default([])
  item10Surveillance       String[]         @default([])
  permissionArtefactId     String[]         @default([])
  validatedAtUtc           DateTime?
  validationResultJson     String?
  status                   FlightPlanStatus @default(DRAFT)
  flightRules              FlightRules      @default(VFR)
  flightType               FlightType       @default(G)
  aircraftId               String
  aircraftType             String
  wakeTurbulence           String           @default("L")
  equipment                String           @default("S")
  surveillance             String?
  survivalEquipment        String?
  adep                     String
  ades                     String
  altn1                    String?
  altn2                    String?
  eobt                     DateTime
  originalEobt             DateTime?     // Preserved on first DLA — never overwritten after initial set
  eet                      String
  totalEet                 String?
  endurance                String?
  personsOnBoard           Int?
  route                    String
  cruisingLevel            String
  cruisingSpeed            String
  // Notification status
  confirmationEmailSentAt  DateTime?
  confirmationEmailStatus  String?
  confirmationSmsSentAt    DateTime?
  confirmationSmsStatus    String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  // AFTN gateway result fields
  aftnTransmissionStatus   String?       // 'STUB' | 'LIVE' | 'FAILED'
  aftnGatewayResultJson    String?       // full AftnGatewayResult JSON from gateway
  aftnTransmittedAt        DateTime?     // when transmit() was called

  // CNL/ARR/DLA message storage
  cnlAftnMessage           String?       // built CNL AFTN string
  arrAftnMessage           String?       // built ARR AFTN string
  dlaAftnMessage           String?       // built DLA AFTN string
  dlaFiledAt               DateTime?     // when DLA was filed

  // CNL/DLA tracking fields
  cancelledAt              DateTime?
  cancelledBy              String?
  cancellationReason       String?
  delayedNewEobt           DateTime?
  delayReason              String?
  arrivedAt                DateTime?
  actualArrivalTime        String?       // HHmm UTC — ATA from pilot

  // Amendment tracking (edit-before-clearance)
  amendmentCount           Int              @default(0)
  lastAmendmentAt          DateTime?
  additionalEmails         String[]         @default([])

  // Clearance notification tracking
  adcNotificationSentAt    DateTime?
  ficNotificationSentAt    DateTime?
  fullyClearedNotifSentAt  DateTime?

  // AAI data sync — tracks when status was reported to AAI
  aaiReportedAt            DateTime?

  civilianFiler            CivilianUser?    @relation("FiledByCivilian", fields: [filedBy], references: [id], map: "MannedFlightPlan_civilianFiler_fkey")
  specialFiler             SpecialUser?     @relation("FiledBySpecial", fields: [filedBy], references: [id], map: "MannedFlightPlan_specialFiler_fkey")
  adcRecords               AdcRecord[]

  @@index([filedBy])
  @@index([adep, ades])
}

model DroneMission {
  id                      String              @id @default(cuid())
  missionId               String              @unique
  deviceNonce             String?             @unique
  operatorId              String
  operatorType            String              @default("CIVILIAN")
  deviceId                String
  deviceModel             String?
  npntClassification      NpntClass
  permissionArtefactId    String?
  missionStartUtcMs       String
  missionEndUtcMs         String?
  ntpSyncStatus           NtpSyncStatus       @default(SYNCED)
  ntpOffsetMs             Int?
  certValidAtStart        Boolean             @default(false)
  certExpiryUtcMs         String?
  deviceCertDer           String?
  chainVerifiedByServer   Boolean             @default(false)
  chainFailureSequence    Int?
  uploadStatus            MissionUploadStatus @default(PENDING)
  uploadedAt              DateTime            @default(now())
  isDuplicate             Boolean             @default(false)
  duplicateOfMissionId    String?
  strongboxBacked         Boolean?
  secureBootVerified      Boolean?
  androidVersionAtUpload  String?
  sensorHealthSummaryFlags Int?
  recordsWithDegradedGps  Int?
  archivedCrlBase64       String?
  serverReceivedAtUtcMs   String?

  // ── Drone category fields (DGCA UAS Rules 2021) ──
  droneWeightCategory     DroneWeightCategory @default(UNKNOWN)
  droneWeightGrams        Int?                // actual weight in grams if known
  droneManufacturer       String?             // "DJI", "Autel", "ideaForge", etc.
  droneSerialNumber       String?             // manufacturer serial / UIN
  nanoAckNumber           String?             // nano drone acknowledgement number (< 250g)
  uinNumber               String?             // UIN for micro+ categories
  npntExempt              Boolean             @default(false) // true for nano drones

  // ── Phase 1 PQC (ML-DSA-65, FIPS 204) ──
  pqcPublicKeyHex         String?             // ML-DSA-65 public key for hybrid verification

  // ── Manufacturer push source (if data came via vendor API) ──
  manufacturerPushId      String?             // FK to ManufacturerPushBatch if vendor-pushed
  manufacturerSource      String?             // DJI | AUTEL | PARROT | etc.

  telemetryRecords        DroneTelemetryRecord[]
  violations              DroneViolation[]
  overrides               DroneMissionOverride[]

  @@index([operatorId])
  @@index([uploadedAt])
  @@index([droneWeightCategory])
  @@index([droneManufacturer])
}

// ── Drone Operation Plans ────────────────────────────────────────────────────
// Pre-flight operation area planning for drone missions.
// Users define a geographic boundary (polygon or circle) + altitude limits.
model DroneOperationPlan {
  id                String   @id @default(cuid())
  planId            String   @unique                // human-readable ID e.g. DOP-2026-00042
  operatorId        String                          // → CivilianUser who filed
  droneSerialNumber String                          // registered drone serial
  uinNumber         String?                         // UIN if available
  areaType          String                          // 'POLYGON' | 'CIRCLE'
  areaGeoJson       String?                         // GeoJSON Polygon (for POLYGON type)
  centerLatDeg      Float?                          // center lat (for CIRCLE type)
  centerLonDeg      Float?                          // center lon (for CIRCLE type)
  radiusM           Float?                          // radius in meters (for CIRCLE type)
  maxAltitudeAglM   Float                           // ceiling in meters AGL
  minAltitudeAglM   Float    @default(0)            // floor in meters AGL
  plannedStartUtc   DateTime
  plannedEndUtc     DateTime
  purpose           String                          // e.g. SURVEY, PHOTOGRAPHY, INSPECTION, DELIVERY
  remarks           String?
  status            String   @default("DRAFT")      // DRAFT | SUBMITTED | APPROVED | REJECTED | CANCELLED
  rejectionReason   String?
  notifyEmail       String?
  notifyMobile      String?
  additionalEmails  String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  submittedAt       DateTime?
  approvedAt        DateTime?
  approvedBy        String?
  // Yellow-zone routing (populated by /drone/yellow-zone-route)
  routingAuthority  String?
  expeditedFlag     Boolean?
  routedAt          DateTime?
  approvalDueBy     DateTime?
  // Digital Sky validation on submit
  digitalSkyRegStatus String?                        // result from Digital Sky check
  digitalSkyCheckAt   DateTime?
  // Flight feedback (post-approval)
  flightFeedback    String?                          // 'FLEW' | 'DID_NOT_FLY'
  flightFeedbackAt  DateTime?
  trackLogId        String?                          // → TrackLog if FLEW

  artefacts         PermissionArtefact[]

  @@index([operatorId])
  @@index([status])
  @@index([plannedStartUtc, plannedEndUtc])
}

// ── Permission Artefact Lifecycle ────────────────────────────────────────────
// Tracks the full lifecycle of a DGCA Permission Artefact (PA) from submission
// through eGCA to download, verification, flight log upload, and archival.
// Per NPNT (No Permission No Takeoff) compliance under DGCA UAS Rules 2021.
model PermissionArtefact {
  id                    String    @id @default(uuid())
  applicationId         String    @unique                // eGCA application reference
  planId                String                           // → DroneOperationPlan
  permissionArtifactId  String?                          // eGCA-assigned PA identifier
  txnId                 String?                          // eGCA transaction reference
  uinNumber             String                           // drone UIN
  pilotId               String                           // pilot business identifier
  operatorId            String                           // operator who submitted
  status                PAStatus                         // lifecycle state machine
  primaryZone           String                           // GREEN | YELLOW | RED
  flightStartTime       DateTime                         // planned start
  flightEndTime         DateTime                         // planned end
  geofencePolygon       Json                             // GeoJSON polygon boundary
  maxAltitudeMeters     Int                              // ceiling in meters AGL
  rawPaXml              Bytes?                           // encrypted PA XML content
  paZipHash             String?                          // SHA-256 of downloaded PA ZIP
  paFilePath            String?                          // Local storage path (legacy)
  signatureValid        Boolean?                         // W3C XMLDSig RSA-SHA256 verification result
  loadedToDroneAt       DateTime?                        // when PA was loaded to drone
  flightLogUploadedAt   DateTime?                        // when flight log was uploaded
  flightLogHash         String?                          // SHA-256 of uploaded flight log
  violations            Json?                            // violation report from processFlightLog
  submittedAt           DateTime                         // When submitted to eGCA
  approvedAt            DateTime?                        // When eGCA approved
  downloadedAt          DateTime?                        // When PA ZIP was downloaded
  expiresAt             DateTime?                        // PA expiry time
  completedAt           DateTime?                        // When flight cycle completed
  archivedAt            DateTime?                        // When archived after expiry
  revokedAt             DateTime?                        // When revoked
  revokeReason          String?                          // Reason for revocation
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  plan                  DroneOperationPlan @relation(fields: [planId], references: [id])

  @@index([status])
  @@index([expiresAt])
  @@index([planId])
  @@index([operatorId])
  @@index([uinNumber])
}

model DroneTelemetryRecord {
  id                  String       @id @default(cuid())
  missionId           String
  sequence            Int
  canonicalPayloadHex String
  chainHashHex        String
  signatureHex        String
  pqcSignatureHex     String?             // ML-DSA-65 (FIPS 204) signature — Phase 1 hybrid PQC
  prevHashPrefixHex   String
  crc32Valid          Boolean
  gnssStatus          String
  sensorHealthFlags   Int          @default(0)
  decodedJson         String
  recordedAtUtcMs     String

  mission             DroneMission @relation(fields: [missionId], references: [id])

  @@index([missionId])
  @@index([sequence])
}

model DroneViolation {
  id              String            @id @default(cuid())
  missionId       String
  sequence        Int
  violationType   ViolationType
  severity        ViolationSeverity
  timestampUtcMs  String
  detailJson      String
  overriddenBy    String?
  overrideReason  String?
  overriddenAt    DateTime?

  mission         DroneMission      @relation(fields: [missionId], references: [id])

  @@index([missionId])
}

model DroneMissionOverride {
  id           String       @id @default(cuid())
  missionId    String
  overriddenBy String
  reason       String
  overrideType String
  createdAt    DateTime     @default(now())

  mission      DroneMission @relation(fields: [missionId], references: [id])
}

model AdcRecord {
  id               String            @id @default(cuid())
  flightPlanId     String?
  afmluId          Int?
  adcNumber        String            @unique
  adcType          String?
  areaGeoJson      String?
  lowerFt          Int               @default(0)
  lowerRef         String            @default("AGL")
  upperFt          Int               @default(0)
  upperRef         String            @default("AGL")
  effectiveFrom    DateTime?
  effectiveTo      DateTime?
  activitySchedule String?
  contactFrequency String?
  issuedBy         String?
  issuedAt         DateTime          @default(now())
  validFrom        DateTime?
  validTo          DateTime?
  remarks          String?
  isActive         Boolean           @default(true)
  pulledAtUtc      DateTime          @default(now())

  flightPlan       MannedFlightPlan? @relation(fields: [flightPlanId], references: [id])

  @@unique([afmluId, adcNumber])
}

model FicRecord {
  id            String    @id @default(cuid())
  ficNumber     String    @unique
  firCode       String
  subject       String
  content       String
  category      String    @default("GENERAL")
  effectiveFrom DateTime
  effectiveTo   DateTime?
  issuedBy      String
  issuedAtUtc   DateTime  @default(now())
  fetchedAt     DateTime  @default(now())
  supersedes    String?
  isActive      Boolean   @default(true)
  lastFetchedAt DateTime?
}

model NotamRecord {
  id               String    @id @default(cuid())
  notamId          String?   @unique
  notamNumber      String?   @unique
  notamSeries      String?
  series           String?
  number           Int?
  year             Int?
  type             String?
  notamType        String?
  firCode          String?
  location         String?
  subject          String?
  condition        String?
  traffic          String?
  purpose          String?
  scope            String?
  lowerFl          Int?
  upperFl          Int?
  lowerFt          Int?
  upperFt          Int?
  areaGeoJson      String?
  effectiveFrom    DateTime
  effectiveTo      DateTime?
  content          String?
  rawText          String?
  isActive         Boolean   @default(true)
  issuingAuthority String?
  lastFetchedAt    DateTime?
  pulledAtUtc      DateTime?
  fetchedAt        DateTime  @default(now())
}

model MetarRecord {
  id              String    @id @default(cuid())
  icao            String?
  icaoCode        String?
  rawMetar        String?
  rawText         String?
  observedAt      DateTime?
  observationUtc  DateTime?
  windDirection   Int?
  windDirDeg      Int?
  windSpeedKt     Int?
  windGustKt      Int?
  visibilityM     Int?
  tempC           Float?
  dewpointC       Float?
  dewPointC       Float?
  qnhHpa          Float?
  altimeterHpa    Float?
  isSpeci         Boolean   @default(false)
  fetchedAt       DateTime  @default(now())
}

model AerodromeRecord {
  id                   String   @id @default(cuid())
  icao                 String?  @unique
  icaoCode             String?
  iata                 String?
  name                 String
  city                 String
  state                String?
  country              String   @default("IN")
  latitudeDeg          Float?
  longitudeDeg         Float?
  latDeg               Float?
  lonDeg               Float?
  elevationFt          Int?
  magneticVariation    Float?
  type                 String   @default("AIRPORT")
  aerodromeType        String?
  status               String?
  firCode              String?
  transitionAltitudeFt Int?
  transitionLevelFl    Int?
  isActive             Boolean  @default(true)
  runways              String?
}

model EvidenceLedger {
  id                String   @id @default(cuid())
  anchorDate        DateTime @db.Date
  missionCount      Int      @default(0)
  missionIdsCsvHash String
  anchorHash        String
  prevAnchorHash    String
  computedAt        DateTime @default(now())
  jobRunId          String

  // RFC 3161 TSA fields — external timestamp authority proof
  rfc3161TimestampToken  String?    // Base64 DER-encoded RFC 3161 TimeStampToken
  tsaName                String?    // 'CDAC' | 'eMudhra' — TSA that issued the token
  tsaTimestamp           DateTime?  // confirmed time extracted from the TSA token
  tsaRequestHash         String?    // hash submitted to TSA — must match anchorHash

  @@unique([anchorDate])
  @@index([anchorDate])
}

// ═══════════════════════════════════════════════
// MANUFACTURER AUTO-SHARE — vendor push + deferred sync
// ═══════════════════════════════════════════════

// Registered manufacturer API credentials.
// Each drone OEM (DJI, Autel, etc.) gets a unique vendorKey.
// When Indian govt mandates auto-share, this is the registry.
model ManufacturerVendor {
  id              String                @id @default(cuid())
  vendorCode      ManufacturerPushSource
  vendorName      String                // "DJI Technology Co., Ltd."
  vendorKeyHash   String                // bcrypt hash of the API key
  webhookUrl      String?               // optional: JADS pushes acknowledgements here
  isActive        Boolean               @default(true)
  registeredAt    DateTime              @default(now())
  registeredBy    String                // admin who onboarded this vendor
  lastPushAt      DateTime?             // last successful push from this vendor
  totalBatches    Int                   @default(0)
  totalFlights    Int                   @default(0)

  batches         ManufacturerPushBatch[]

  @@unique([vendorCode])
}

// A batch of flight data pushed by a manufacturer.
// Supports both real-time (after landing) and deferred (post-connectivity).
model ManufacturerPushBatch {
  id                  String              @id @default(cuid())
  vendorId            String
  batchReference      String              @unique  // vendor's unique batch ID (idempotency key)
  pushType            String              // REAL_TIME | DEFERRED
  // DEFERRED = data collected offline, pushed when connectivity available
  // REAL_TIME = pushed immediately after drone landing
  deferredReason      String?             // "NO_CONNECTIVITY" | "REMOTE_AREA" | "OPERATOR_DELAYED"
  deferredSinceUtcMs  String?             // when the data was originally captured
  receivedAtUtcMs     String              // when JADS server received it
  status              DeferredSyncStatus  @default(QUEUED)
  flightCount         Int                 @default(0)
  processedCount      Int                 @default(0)
  failedCount         Int                 @default(0)
  errorDetails        String?             // JSON array of per-flight errors
  processedAt         DateTime?

  vendor              ManufacturerVendor  @relation(fields: [vendorId], references: [id])
  flights             ManufacturerPushFlight[]

  @@index([vendorId])
  @@index([status])
  @@index([receivedAtUtcMs])
}

// Individual flight record within a manufacturer push batch.
// This is the raw data from the drone itself — higher fidelity than phone GPS.
model ManufacturerPushFlight {
  id                    String              @id @default(cuid())
  batchId               String
  vendorFlightId        String              // manufacturer's internal flight ID
  droneSerialNumber     String              // drone hardware serial
  droneModel            String              // "Mavic 3 Enterprise", "EVO II Pro", etc.
  droneWeightCategory   DroneWeightCategory @default(UNKNOWN)
  operatorId            String?             // DGCA-registered operator ID if known
  pilotId               String?             // DGCA-registered pilot ID if known

  // Flight metadata
  flightStartUtcMs      String
  flightEndUtcMs        String
  takeoffLatDeg         Float
  takeoffLonDeg         Float
  landingLatDeg         Float?
  landingLonDeg         Float?
  maxAltitudeMeters     Float?
  maxSpeedMs            Float?
  totalDistanceMeters   Float?

  // Raw telemetry — stored as JSON array of {lat, lon, alt, timestamp, speed, heading}
  telemetryJson         String              // full GPS track from drone's own sensors
  telemetryPointCount   Int                 @default(0)
  telemetryHz           Float?              // sampling rate (DJI = 10Hz typically)

  // Linkage — after processing, linked to a DroneMission if one exists
  linkedMissionId       String?             // FK to DroneMission.id if matched
  matchConfidence       Float?              // 0.0–1.0, how confident the time/location match is

  // Validation
  ingestionStatus       String              @default("PENDING") // PENDING | INGESTED | FAILED | SKIPPED
  ingestionError        String?
  processedAt           DateTime?

  batch                 ManufacturerPushBatch @relation(fields: [batchId], references: [id])

  @@index([batchId])
  @@index([droneSerialNumber])
  @@index([operatorId])
  @@index([flightStartUtcMs])
  @@unique([batchId, vendorFlightId])
}

// ═══════════════════════════════════════════════
// BSA 2023 Section 63 Part B Declarations
// ═══════════════════════════════════════════════
// Stores the signed declaration by an authorised officer
// confirming that conditions of BSA Section 63 are satisfied.
// Each declaration is linked to a specific Part A certificate.

model Bsa2023PartBDeclaration {
  id                   String   @id @default(cuid())
  missionId            String   // FK to DroneMission.id
  certificateId        String   // Part A certificate reference (e.g. BSA63-xxx-yyy)

  // Declarant identity
  declarantName        String   // Full name of the authorised officer
  declarantDesignation String   // e.g. "Deputy Director, DGCA"
  declarantEntityCode  String   // e.g. "DGCA", "IAF", "ARMY"
  declarantUserId      String   // FK to SpecialUser.id who signed

  // Declaration content
  declarationText      String   // The full declaration statement
  allInvariantsHeld    Boolean  // Whether all invariants held at time of declaration
  conditionsSatisfied  Boolean  // Officer's affirmation that BSA §63 conditions are met

  // Signature
  signedAtUtc          DateTime @default(now())
  signatureMethod      String   @default("DIGITAL_JWT") // DIGITAL_JWT | DIGITAL_DSC | WET_INK_SCANNED

  // Audit trail
  ipAddress            String?
  userAgent            String?

  createdAt            DateTime @default(now())

  @@index([missionId])
  @@index([certificateId])
  @@index([declarantUserId])
}

// ═══════════════════════════════════════════════
// NOTIFICATION ENGINE — in-app + email alerts
// ═══════════════════════════════════════════════

enum NotificationType {
  // N01–N05: Expiry alerts
  EXPIRY_90_DAYS           // N01 — licence/UIN approaching expiry (90 days)
  EXPIRY_60_DAYS           // N02 — 60 days to expiry
  EXPIRY_30_DAYS           // N03 — 30 days to expiry
  EXPIRY_7_DAYS            // N04 — 7 days to expiry (urgent)
  EXPIRY_EXPIRED           // N05 — licence/UIN/PA has expired
  // N06–N10: Permission lifecycle events
  PERMISSION_SUBMITTED     // N06 — PA application submitted to eGCA
  PERMISSION_APPROVED      // N07 — PA approved by authority
  PERMISSION_REJECTED      // N08 — PA rejected by authority
  PERMISSION_DOWNLOADED    // N09 — PA ZIP downloaded successfully
  PERMISSION_REVOKED       // N10 — PA revoked post-approval
  // N11–N13: Compliance & system events
  VIOLATION_DETECTED       // N11 — airspace/geofence violation detected
  COMPLIANCE_WARNING       // N12 — compliance issue (e.g. chain break)
  SYSTEM_BROADCAST         // N13 — admin broadcast message
}

model NotificationRecord {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  metadata  Json             @default("{}")
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  readAt    DateTime?

  @@index([userId])
  @@index([type])
  @@index([read])
  @@index([createdAt])
}

// ═══════════════════════════════════════════════
// LIVE TELEMETRY — T01/T09/T10
// ═══════════════════════════════════════════════

// T01 — Live telemetry point ingested from field phone
model TelemetryPoint {
  id             String   @id @default(cuid())
  missionId      String
  uin            String
  lat            Float
  lon            Float
  altAGL         Float
  altMSL         Float
  speedKmh       Float
  headingDeg     Float
  batteryPct     Float
  satelliteCount Int
  source         String
  ts             BigInt
  createdAt      DateTime @default(now())

  @@index([missionId, ts])
}

// T09 — Geofence violation detected in real time
model GeofenceViolation {
  id               String   @id @default(cuid())
  missionId        String
  uin              String
  violationType    String   // GEOFENCE_BREACH | ALTITUDE_VIOLATION | TIME_WINDOW_VIOLATION
  severity         String   // LOW | MEDIUM | HIGH | CRITICAL
  lat              Float
  lon              Float
  altAGL           Float
  detailJson       String
  evidenceHash     String   // SHA-256 hash for evidence chain
  prevEvidenceHash String   // previous hash in chain
  detectedAt       DateTime @default(now())

  @@index([missionId])
  @@index([detectedAt])
}

// T10 — Incident reports created by admin from violation alerts
model IncidentReport {
  id               String   @id @default(cuid())
  violationId      String
  missionId        String
  uin              String
  reportedBy       String   // admin user ID
  description      String
  severity         String   // LOW | MEDIUM | HIGH | CRITICAL
  actionTaken      String?
  status           String   @default("OPEN") // OPEN | UNDER_REVIEW | RESOLVED | CLOSED
  assignedTo       String?
  resolvedAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([missionId])
  @@index([status])
  @@index([createdAt])
}
